# Environment Configuration for YSU Emergency Response System
# Copy this file to .env and update the values

# Environment
APP_ENV=development

# Database Configuration
DB_HOST=localhost
DB_NAME=emergency_response_system
DB_USER=root
DB_PASSWORD=
DB_PORT=3306

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# API Configuration
API_BASE_URL=http://localhost/emergency-response-server/api
CORS_ORIGIN=http://localhost:3000

# File Upload Configuration
UPLOAD_BASE_URL=http://localhost/emergency-response-server/uploads/

# Email Configuration
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
SMTP_FROM_EMAIL=noreply@ysu.edu.ng

# Firebase Cloud Messaging (Optional)
FCM_SERVER_KEY=
FCM_SENDER_ID=

# SMS Configuration (Optional)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Emergency Contacts
SECURITY_PHONE=08012345678
SECURITY_EMAIL=security@ysu.edu.ng
HEALTH_PHONE=08012345679
HEALTH_EMAIL=health@ysu.edu.ng
FIRE_PHONE=08012345680
FIRE_EMAIL=fire@ysu.edu.ng

# Cache Configuration (Optional)
CACHE_DRIVER=file
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0