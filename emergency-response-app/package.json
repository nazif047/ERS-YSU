{
  "name": "emergency-response-app",
  "version": "1.0.0",
  "description": "Yobe State University Emergency Response System",
  "main": "App.js",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "clean": "react-native clean",
    "build:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "build:ios": "react-native bundle --platform ios --dev false --entry-file index.js --bundle-output ios/main.jsbundle"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.72.6",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "react-native-screens": "^3.27.0",
    "react-native-safe-area-context": "^4.7.4",
    "react-native-gesture-handler": "^2.13.4",
    "react-native-vector-icons": "^10.0.2",
    "axios": "^1.6.2",
    "react-native-async-storage": "^1.21.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-elements": "^3.4.3",
    "react-native-paper": "^5.11.6",
    "react-native-geolocation-service": "^5.3.1",
    "react-native-permissions": "^3.10.1",
    "react-native-device-info": "^10.11.0",
    "react-native-haptic-feedback": "^2.2.0",
    "react-native-keychain": "^8.1.3",
    "react-native-reanimated": "^3.6.2",
    "react-native-svg": "^13.14.0",
    "react-native-svg-transformer": "^1.3.0",
    "react-native-image-picker": "^5.6.0",
    "react-native-calendar-picker": "^7.1.4",
    "react-native-chart-kit": "^6.12.0",
    "react-native-svg-charts": "^5.4.0",
    "react-native-dialog": "^9.3.0",
    "react-native-dropdown-picker": "^5.4.6",
    "react-native-flash-message": "^0.4.2",
    "react-native-loading-spinner-overlay": "^3.0.1",
    "react-native-swipeout": "^2.3.6",
    "react-native-tab-view": "^3.5.2",
    "moment": "^2.29.4",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "@babel/runtime": "^7.23.6",
    "@react-native/metro-config": "^0.72.11",
    "@tsconfig/react-native": "^3.0.2",
    "@types/react": "^18.2.45",
    "@types/react-test-renderer": "^18.0.2",
    "babel-jest": "^29.7.0",
    "eslint": "^8.56.0",
    "eslint-config-react-app": "^7.0.1",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "prettier": "^3.1.1",
    "react-test-renderer": "^18.2.0"
  },
  "jest": {
    "preset": "react-native",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|react-native-vector-icons|react-native-elements|react-native-svg)/)"
    ]
  },
  "metro": {
    "transformer": {
      "babelTransformerPath": require.resolve("react-native-svg-transformer")
    },
    "resolver": {
      "assetExts": ["png", "jpg", "jpeg", "gif", "svg"]
    }
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "react-native",
    "emergency-response",
    "yobe-state-university",
    "mobile-app",
    "safety"
  ],
  "author": "Yobe State University Emergency Response Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ysu/emergency-response-system.git"
  },
  "bugs": {
    "url": "https://github.com/ysu/emergency-response-system/issues"
  },
  "homepage": "https://ysu.edu.ng/emergency-response"
}